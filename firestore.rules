rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Estrutura Principal: companies/{userId}/{collection}/{document}
    // Alinhado com auth-system.js, firebase-sync.js e serviços de faturamento
    match /companies/{userId} {
      // Permite que o utilizador gerencie os dados da sua própria empresa
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Regras para subcoleções (expenses, invoicesIssued, invoicesReceived, budgets, clients, providers)
      match /{collection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Bloqueio padrão para qualquer outro caminho não especificado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
